{
  "manifest_version": 3,
  "name": "YouTube 영상 요약기",
  "version": "1.0",
  "description": "YouTube 영상을 자동으로 요약합니다",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://claude.ai/*",
    "http://192.168.0.43:5000/*",
    "https://pleasing-tahr-randomly.ngrok-free.app/*",
    "https://*.ngrok-free.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["*://*.youtube.com/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}